pipeline {

    agent any

    parameters {

        choice(
            name: 'BROWSER',
            choices: ['chrome', 'firefox', 'all'],
            description: 'Select Browser'
        )

        choice(
            name: 'ENVIRONMENT',
            choices: ['qa', 'uat', 'prod'],
            description: 'Select Environment'
        )

    }

    environment {

        GEMINI_API_KEY = credentials('gemini-api-key')
        HEADLESS = 'true'

    }

    stages {

        stage('Checkout') {

            steps {
                checkout scm
            }
        }

        stage('Run Tests') {


            steps {

                sh """
                export BROWSER=${params.BROWSER}
                export ENVIRONMENT=${params.ENVIRONMENT}
                export SUITE=${params.SUITE}

                python3 run_tests.py
                """
            }
        }
    }

    post {

        always {

            archiveArtifacts(
                artifacts: 'reports/**/*',
                fingerprint: true
            )

            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: false,
                keepAll: true,
                reportDir: 'reports',
                reportFiles: 'ai_execution_report.html',
                reportName: 'AI Automation Report'
            ])
            emailext(
                subject: "AI Framework Build: ${currentBuild.currentResult}",
                body: """
                <h2>AI Automation Execution</h2>

                <p><b>Job:</b> ${env.JOB_NAME}</p>
                <p><b>Build:</b> #${env.BUILD_NUMBER}</p>
                <p><b>Status:</b> ${currentBuild.currentResult}</p>

                <p>
                  Report:
                  <a href="${env.BUILD_URL}AI_20Automation_20Report/">
                  Open HTML Report
                  </a>
                </p>

                <p>
                  Console:
                  <a href="${env.BUILD_URL}console">
                  View Console Output
                  </a>
                </p>
                """,
                to: "nageshgorre007@gmail.com"
            )
        }
    }
}